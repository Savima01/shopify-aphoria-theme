{%- style -%}
  #aphoria-fc-{{ section.id }} {
    --fc-bg: {{ section.settings.bg_color }};
    --fc-cols: {{ section.settings.columns }};
  }
{%- endstyle -%}

<section id="aphoria-fc-{{ section.id }}" class="aphoria-fc">
  <div class="aphoria-container">

    {%- if section.settings.eyebrow != blank -%}
      <p class="aphoria-label aphoria-fc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="aphoria-heading aphoria-fc__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- assign col = collections[section.settings.collection] -%}
    {%- assign products = col.products | default: (1..4) -%}

    <div class="aphoria-fc__grid">
      {%- for product in products limit: section.settings.products_to_show -%}
        <a href="{{ product.url }}" class="aphoria-fc__card">
          <div class="aphoria-fc__card-media">
            {%- if product.featured_image -%}
              {{
                product.featured_image
                | image_url: width: 800
                | image_tag:
                  class: 'aphoria-fc__card-img',
                  loading: 'lazy',
                  widths: '300,400,600,800',
                  sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 100vw'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'aphoria-fc__card-placeholder' }}
            {%- endif -%}
            <div class="aphoria-fc__card-overlay">
              <span class="aphoria-btn aphoria-btn--ghost aphoria-fc__quick-view">
                {{ 'sections.aphoria_fc.quick_view' | t | default: 'Ansehen' }}
              </span>
            </div>
          </div>
          <div class="aphoria-fc__card-info">
            <p class="aphoria-fc__card-vendor aphoria-label">{{ product.vendor }}</p>
            <h3 class="aphoria-fc__card-title">{{ product.title }}</h3>
            <p class="aphoria-fc__card-price">{{ product.price | money }}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="aphoria-fc__cta">
        <a href="{{ section.settings.button_url | default: '/collections/all' }}" class="aphoria-btn aphoria-btn--noir">
          {{ section.settings.button_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.aphoria-fc {
  background: var(--fc-bg, var(--aphoria-ivory));
  padding: clamp(60px, 8vw, 120px) 0;
}

.aphoria-fc__eyebrow {
  color: var(--aphoria-bordeaux);
  margin-bottom: 12px;
  text-align: center;
  font-size: var(--aphoria-label-sz);
  letter-spacing: 0.25em;
}

.aphoria-fc__heading {
  font-size: var(--aphoria-h2);
  font-family: 'Bodoni Moda', Georgia, serif;
  font-style: italic;
  font-weight: 400;
  color: var(--aphoria-noir);
  text-align: center;
  margin-bottom: clamp(40px, 6vw, 72px);
  line-height: 1.1;
}

.aphoria-fc__grid {
  display: grid;
  grid-template-columns: repeat(var(--fc-cols, 4), 1fr);
  gap: 24px;
}

@media (max-width: 989px) {
  .aphoria-fc__grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 599px) {
  .aphoria-fc__grid { grid-template-columns: 1fr; gap: 32px; }
}

.aphoria-fc__card {
  text-decoration: none;
  color: inherit;
  display: block;
}

.aphoria-fc__card-media {
  position: relative;
  aspect-ratio: 3 / 4;
  overflow: hidden;
  background: var(--aphoria-rose-copper-pale);
  margin-bottom: 16px;
}

.aphoria-fc__card-img,
.aphoria-fc__card-placeholder {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  display: block;
}

.aphoria-fc__card:hover .aphoria-fc__card-img,
.aphoria-fc__card:hover .aphoria-fc__card-placeholder {
  transform: scale(1.05);
}

.aphoria-fc__card-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 2, 5, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.aphoria-fc__card:hover .aphoria-fc__card-overlay {
  opacity: 1;
}

.aphoria-fc__quick-view {
  font-size: 11px;
  padding: 10px 20px;
  pointer-events: none;
}

.aphoria-fc__card-vendor {
  color: var(--aphoria-bordeaux);
  margin-bottom: 4px;
  font-size: var(--aphoria-label-sz);
  letter-spacing: 0.18em;
}

.aphoria-fc__card-title {
  font-family: 'Bodoni Moda', Georgia, serif;
  font-size: var(--aphoria-h3);
  font-weight: 400;
  font-style: italic;
  color: var(--aphoria-noir);
  margin-bottom: 8px;
  line-height: 1.25;
}

.aphoria-fc__card-price {
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.06em;
  color: var(--aphoria-bordeaux);
}

.aphoria-fc__cta {
  text-align: center;
  margin-top: clamp(40px, 5vw, 64px);
}
{% endstylesheet %}

{% schema %}
{
  "name": "Highlight Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Text",
      "default": "Our Bestsellers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Headline",
      "default": "The Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of Products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#FAF6F3"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View All Products"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Highlight Collection (EN)",
      "settings": {
        "eyebrow": "Our Bestsellers",
        "heading": "The Collection",
        "products_to_show": 4,
        "columns": 4,
        "button_label": "View All Products"
      }
    },
    {
      "name": "Highlight Kollektion (DE)",
      "settings": {
        "eyebrow": "Unsere Bestseller",
        "heading": "Die Kollektion",
        "products_to_show": 4,
        "columns": 4,
        "button_label": "Alle Produkte ansehen"
      }
    }
  ]
}
{% endschema %}
