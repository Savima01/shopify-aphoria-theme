{%- style -%}
  .aphoria-lkcta {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color }};
    text-align: center;
  }

  .aphoria-lkcta__inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .aphoria-lkcta__eyebrow {
    font-family: var(--font-body-family);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 1.6rem;
  }

  .aphoria-lkcta__heading {
    font-family: var(--font-heading-family);
    font-style: italic;
    font-weight: 400;
    font-size: {{ section.settings.heading_size }}px;
    color: {{ section.settings.text_color }};
    line-height: 1.15;
    margin: 0 0 1.6rem;
  }

  .aphoria-lkcta__subtext {
    font-family: var(--font-body-family);
    font-size: 15px;
    color: {{ section.settings.text_color }};
    opacity: 0.7;
    margin-bottom: 3rem;
    line-height: 1.7;
  }

  .aphoria-lkcta__buttons {
    display: flex;
    gap: 1.6rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .aphoria-lkcta__btn {
    display: inline-block;
    padding: 1.4rem 3.2rem;
    font-family: var(--font-body-family);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 4px;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .aphoria-lkcta__btn--primary {
    background: {{ section.settings.btn_primary_bg }};
    color: {{ section.settings.btn_primary_text }};
    border: 1.5px solid {{ section.settings.btn_primary_bg }};
  }

  .aphoria-lkcta__btn--primary:hover {
    background: transparent;
    color: {{ section.settings.btn_primary_bg }};
  }

  .aphoria-lkcta__btn--secondary {
    background: transparent;
    color: {{ section.settings.text_color }};
    border: 1.5px solid {{ section.settings.text_color }};
    opacity: 0.7;
  }

  .aphoria-lkcta__btn--secondary:hover {
    opacity: 1;
  }
{%- endstyle -%}

<div class="aphoria-lkcta">
  <div class="aphoria-lkcta__inner">
    {%- if section.settings.eyebrow != blank -%}
      <p class="aphoria-lkcta__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="aphoria-lkcta__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="aphoria-lkcta__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="aphoria-lkcta__buttons">
      {%- if section.settings.btn1_label != blank -%}
        <a class="aphoria-lkcta__btn aphoria-lkcta__btn--primary" href="{{ section.settings.btn1_url }}">
          {{ section.settings.btn1_label }}
        </a>
      {%- endif -%}
      {%- if section.settings.btn2_label != blank -%}
        <a class="aphoria-lkcta__btn aphoria-lkcta__btn--secondary" href="{{ section.settings.btn2_url }}">
          {{ section.settings.btn2_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lookbook Abschluss-CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow-Text",
      "default": "Bereit für dein Ritual?"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Die Kollektion entdecken"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Schriftgröße (px)",
      "min": 24,
      "max": 64,
      "step": 2,
      "default": 44
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Beschreibungstext",
      "default": "Alle APHORIA-Produkte vereinen modernste Wissenschaft mit der Kraft reiner Natur."
    },
    {
      "type": "header",
      "content": "Button 1 (Primär)"
    },
    {
      "type": "text",
      "id": "btn1_label",
      "label": "Button Text",
      "default": "Jetzt shoppen"
    },
    {
      "type": "url",
      "id": "btn1_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Button 2 (Sekundär)"
    },
    {
      "type": "text",
      "id": "btn2_label",
      "label": "Button Text",
      "default": "Unsere Geschichte"
    },
    {
      "type": "url",
      "id": "btn2_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten (px)",
      "min": 40,
      "max": 160,
      "step": 8,
      "default": 96
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Hintergrundfarbe",
      "default": "#0A0205"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#FAF6F3"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Akzentfarbe (Eyebrow)",
      "default": "#C9A57E"
    },
    {
      "type": "color",
      "id": "btn_primary_bg",
      "label": "Button 1 Hintergrund",
      "default": "#7C1D3C"
    },
    {
      "type": "color",
      "id": "btn_primary_text",
      "label": "Button 1 Text",
      "default": "#FAF6F3"
    }
  ],
  "presets": [
    {
      "name": "Lookbook Abschluss-CTA"
    }
  ]
}
{% endschema %}
